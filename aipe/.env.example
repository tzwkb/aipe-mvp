# LLM 配置（OpenAI 兼容协议）
LLM_PROVIDER=openai
LLM_MODEL=qwen3.6-plus
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://your-gateway.example.com/v1
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60
LLM_MAX_RETRIES=5

# Embedding 配置（OpenAI 兼容协议）
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1024  # Matryoshka 截断维度，text-embedding-3-large 推荐 1024，不填使用模型默认
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_BASE_URL=https://your-gateway.example.com/v1
EMBEDDING_TIMEOUT=30

# Qdrant 配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=yanyun_corpus

# RAG 配置
RAG_THRESHOLD=0.85
RAG_TOP_K=3

# 批量处理配置
BATCH_SIZE=50
MAX_CONCURRENT=5
BATCH_SLEEP=0.5

# 外部 Web 搜索（博查 / Bocha）——RAG 弱召回 + 术语未命中时兜底
WEB_SEARCH_ENABLED=false
BOCHA_API_KEY=
BOCHA_ENDPOINT=https://api.bocha.cn/v1/web-search
BOCHA_COUNT=8
BOCHA_SUMMARY=true
BOCHA_TIMEOUT=8.0
BOCHA_MAX_RETRIES=1
WEB_SEARCH_DENSE_THRESHOLD=0.6
WEB_SEARCH_MAX_SNIPPETS=3
WEB_SEARCH_SNIPPET_MAX_CHARS=300
WEB_SEARCH_CACHE_DIR=./data/cache/web_search
WEB_SEARCH_CACHE_ENABLED=true

# 路径配置
DATA_DIR=./data
PROGRESS_DIR=./data/progress
